# Copia este archivo como .env y llena los valores
# En Render configura estas variables en Environment Variables

# Tu correo Gmail desde el que se envian los pedidos
EMAIL_USER=tupasteleria@gmail.com

# Contrasena de aplicacion de Gmail (NO tu contrasena normal)
# Ve a: Google Account > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicacion
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Correo donde recibes los pedidos (puede ser el mismo)
EMAIL_CHEF=chef@tupasteleria.com

# Puerto (Render lo asigna automaticamente)
PORT=3000
