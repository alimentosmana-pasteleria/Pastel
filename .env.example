# Copia este archivo como ".env" y rellena (sin comillas en los valores).
# Súbelo a GitHub junto al resto si Render no aplica las variables de entorno.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Opcional (una sola línea JSON): BREVO_SMTP_JSON={"user":"TU_LOGIN@smtp-brevo.com","pass":"xsmtpsib-..."}
FROM_EMAIL=
